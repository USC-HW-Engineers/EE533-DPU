# ══════════════════════════════════════════════════════════════
#  FC: Real FC Layer Inference y = ReLU(W*X+B)
#
#  W = [[ 1,-1, 0, 0],    X = [2,3,1,4]    B = [0.5, 0.5, 0.5, 0.5]
#       [ 0, 1,-1, 0],    (per row)
#       [ 0, 0, 1,-1],
#       [-1, 0, 0, 1]]
#
#  D[0] = 1*2 + (-1)*3 + 0*1 + 0*4 + 0.5 = -0.5   → ReLU → 0
#  D[1] = 0*2 + 1*3 + (-1)*1 + 0*4 + 0.5 =  2.5   → ReLU → 2.5
#  D[2] = 0*2 + 0*3 + 1*1 + (-1)*4 + 0.5 = -2.5   → ReLU → 0
#  D[3] = (-1)*2 + 0*3 + 0*1 + 1*4 + 0.5 =  2.5   → ReLU → 2.5
#
#  Y = [0, 2.5, 0, 2.5]  — two outputs clamped by ReLU
#
#  BF16: -1=BF80 1=3F80 2=4000 3=4040 4=4080 0.5=3F00 2.5=4020
#
#  TX[0] = bank0 D_PACK = {Y[1],Y[0]} = {2.5, 0} = 0x40200000
#                          {Y[3],Y[2]} = {2.5, 0} = 0x40200000
#  TX[1] = bank1 D_PACK (same — all rows of X identical, so
#          row1 of D: 0*2+1*3+(-1)*1+0*4+0.5 = 2.5 → same column pattern)
#
#  Wait — each thread computes a DIFFERENT row of D, but D_PACK reads
#  bank i's DMEM[0..3] which is thread i's output row. So:
#    TX[0] = {CPU[33],CPU[32]} = bank0 = row0 output = [0, 2.5, 0, 2.5]
#    TX[1] = {CPU[35],CPU[34]} = bank1 = row1 output = [2.5, 0, 2.5, 0]
#
#  Row 0: D=[-.5, 2.5, -.5, 2.5] → Y=[0, 2.5, 0, 2.5]
#  Row 1: D=[2.5, -.5, 2.5, -.5] → Y=[2.5, 0, 2.5, 0]
#
#  Hmm wait, need to recompute. X is 4x4 (same row replicated):
#  X = [[2,3,1,4],[2,3,1,4],[2,3,1,4],[2,3,1,4]]
#
#  D[i][j] = sum_k W[i][k]*X[k][j] + B[i][j]
#  Since all rows of X are [2,3,1,4], X[k][j] is the same for all k rows.
#  So D[i][j] = (sum_k W[i][k]) * X[0][j] + B[i][j]
#
#  Nope, that's wrong. D[i][j] = W[i][0]*X[0][j] + W[i][1]*X[1][j] + ...
#  X[0][j]=X[1][j]=X[2][j]=X[3][j] since all rows identical.
#  So D[i][j] = (sum_k W[i][k]) * X[0][j] + B[i][j]
#
#  sum_k W[0][k] = 1-1+0+0 = 0   → D[0][j] = 0*X[0][j]+0.5 = 0.5
#  sum_k W[1][k] = 0+1-1+0 = 0   → D[1][j] = 0*X[0][j]+0.5 = 0.5
#  sum_k W[2][k] = 0+0+1-1 = 0   → D[2][j] = 0*X[0][j]+0.5 = 0.5
#  sum_k W[3][k] = -1+0+0+1 = 0  → D[3][j] = 0*X[0][j]+0.5 = 0.5
#
#  That gives D = all 0.5, Y = all 0.5. Boring because W rows sum to 0.
#
#  Better W: rows don't sum to zero.
#  W = [[ 2, 1, 0, 0],    X = [1,1,1,1]    B = [-3, 0.5, -5, 1]
#       [ 0, 2, 1, 0],    (per row)
#       [ 0, 0, 2, 1],
#       [ 1, 0, 0, 2]]
#
#  D[0] = 2*1+1*1+0+0 + (-3) = 3-3 = 0     → ReLU → 0
#  D[1] = 0+2*1+1*1+0 + 0.5  = 3+0.5 = 3.5 → ReLU → 3.5
#  D[2] = 0+0+2*1+1*1 + (-5) = 3-5 = -2    → ReLU → 0
#  D[3] = 1*1+0+0+2*1 + 1    = 3+1 = 4     → ReLU → 4.0
#
#  Y = [0, 3.5, 0, 4.0]  — two clamped, two pass. Good!
#
#  BF16: 2=4000 1=3F80 -3=C040 0.5=3F00 -5=C0A0 3.5=4060 4=4080
#
#  D_PACK per bank (each bank = one row of output):
#    Bank 0 row 0: Y=[0, 3.5, 0, 4.0]
#      CPU_lo = {Y[1],Y[0]} = {3.5, 0} = {4060, 0000} = 0x40600000
#      CPU_hi = {Y[3],Y[2]} = {4.0, 0} = {4080, 0000} = 0x40800000
#    Bank 1 row 1: same computation (all X rows same, so each D row
#      depends only on W row and B row, which are DIFFERENT per bank)
#      D[1] = 0+2+1+0 + 0.5 = 3.5 → Y[1][j] for all j?
#
#  No — D[i][j] = sum_k W[i][k]*X[k][j] + B[i][j]
#  With X all rows = [1,1,1,1], X[k][j] = 1 for all k,j.
#  D[i][j] = sum_k W[i][k] + B[i][j]
#  But B is a row vector replicated: B[i][j] = B[i] for all j.
#  So D[i][j] = (sum_k W[i][k]) + B[i] — same for all j!
#
#  Row 0: sum_W=3, D[0][*]=3+(-3)=0   → Y=0 for all 4 cols
#  Row 1: sum_W=3, D[1][*]=3+0.5=3.5  → Y=3.5 for all 4 cols
#  Row 2: sum_W=3, D[2][*]=3+(-5)=-2  → Y=0 for all 4 cols
#  Row 3: sum_W=3, D[3][*]=3+1=4      → Y=4.0 for all 4 cols
#
#  D_PACK bank 0: {Y,Y}={0,0}=0x00000000, {Y,Y}={0,0}=0x00000000
#  D_PACK bank 1: {3.5,3.5}=0x40604060, {3.5,3.5}=0x40604060
#
#  TX[0] = {bank0_hi, bank0_lo} = {0x00000000, 0x00000000}
#  TX[1] = {bank1_hi, bank1_lo} = {0x40604060, 0x40604060}
#
#  Total: 30 + 9 + 13 + 8 = 60 words
# ══════════════════════════════════════════════════════════════
sub tfc { banner("FC: y=ReLU(W*X+B), real weights+bias, Y=[0,3.5,0,4]"); ic(); my@c;

  # ARM firmware
  gpu_arm(0x04, 6, 0, 2, 12);  # 30 words

  # GPU kernel (same as before — unchanged)
  @c=cw(2,0,8,0); iw($c[0],$c[1],0);
  iw(0xF0400004,0x20000000,0);  # [1]WMMA.LD R4;  [0]MOVI R0,0
  iw(0xF0000000,0xF0800008,0);  # [3]WMMA.LD R0;  [2]WMMA.LD R8
  iw(0x20000000,0xECC04800,0);  # [5]MOVI R0,0;   [4]WMMA.MMA
  iw(0x54DD0000,0x54CC0000,0);  # [7]MAX.f R13;   [6]MAX.f R12
  iw(0x54FF0000,0x54EE0000,0);  # [9]MAX.f R15;   [8]MAX.f R14
  iw(0xF8C00000,0x20000000,0);  # [11]WMMA.ST;    [10]MOVI R0,0
  iw(0x00000000,0xC8000000,0);  # [13]NOP;         [12]RET
  iw(0x00000000,0x00000000,0);  # pad

  # Matrix data: 12 DWs at addr=16
  # BF16: 1=3F80 2=4000 -3=C040 0.5=3F00 -5=C0A0
  @c=cw(2,0x010,12,0); iw($c[0],$c[1],0);

  # Bank 0: W[0]=[2,1,0,0]  X=[1,1,1,1]  B=[-3,-3,-3,-3]
  iw(0x00000000,0x3F804000,0);  # W: {0,0},{1.0,2.0}
  iw(0x3F803F80,0x3F803F80,0);  # X: {1,1},{1,1}
  iw(0xC040C040,0xC040C040,0);  # B: {-3,-3},{-3,-3}

  # Bank 1: W[1]=[0,2,1,0]  X=[1,1,1,1]  B=[0.5,0.5,0.5,0.5]
  iw(0x00003F80,0x40000000,0);  # W: {0,1.0},{2.0,0}
  iw(0x3F803F80,0x3F803F80,0);  # X: {1,1},{1,1}
  iw(0x3F003F00,0x3F003F00,0);  # B: {0.5,0.5},{0.5,0.5}

  # Bank 2: W[2]=[0,0,2,1]  X=[1,1,1,1]  B=[-5,-5,-5,-5]
  # DMEM[0]=0,DMEM[1]=0,DMEM[2]=2.0(4000),DMEM[3]=1.0(3F80)
  iw(0x3F804000,0x00000000,0);  # W: {1.0,2.0},{0,0}
  iw(0x3F803F80,0x3F803F80,0);  # X: {1,1},{1,1}
  iw(0xC0A0C0A0,0xC0A0C0A0,0);  # B: {-5,-5},{-5,-5}

  # Bank 3: W[3]=[1,0,0,2]  X=[1,1,1,1]  B=[1,1,1,1]
  # W[3]: DMEM[0]=1.0,DMEM[1]=0,DMEM[2]=0,DMEM[3]=2.0
  # CPU word0={0,1.0}={0000,3F80}=0x00003F80
  # CPU word1={2.0,0}={4000,0000}=0x40000000
  iw(0x40000000,0x00003F80,0);  # W: {2.0,0},{0,1.0}
  iw(0x3F803F80,0x3F803F80,0);  # X
  iw(0x3F803F80,0x3F803F80,0);  # B: {1,1},{1,1}

  tail(0x020,4);

  # Expected:
  #   Bank 0 row 0: Y=[0,0,0,0]       → {0,0}=0x00000000, {0,0}=0x00000000
  #   Bank 1 row 1: Y=[3.5,3.5,3.5,3.5] → {3.5,3.5}=0x40604060, same
  # TX[0]={bank0_hi,bank0_lo}={0x00000000,0x00000000}
  # TX[1]={bank1_hi,bank1_lo}={0x40604060,0x40604060}
  id(); c4("FC",pt(300),cr(),0x00000000,0x00000000,0x40604060,0x40604060);
}

