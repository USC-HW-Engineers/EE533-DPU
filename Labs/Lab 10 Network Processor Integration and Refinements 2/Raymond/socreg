# ══════════════════════════════════════════════════════════════
#  T22: Full Heterogeneous (int, +5 -> x2 -> +10 -> +7)
# ══════════════════════════════════════════════════════════════
sub t22 { banner("T22: Full heterogeneous int pipeline\n  [10,20,30,40]+5->x2->+10->+7=[47,67,87,107]"); ic(); my@c;
  # Compact ARM: 42 DWs
  @c=cw(1,0,42,0); iw($c[0],$c[1],0x04);
  # Phase 1: CPU +5 (7 DW)
  iw(0xE5901000,0xE3A00040,0); iw(0xE5801000,0xE2811005,0);
  iw(0xE2811005,0xE5901004,0); iw(0xE5901008,0xE5801004,0);
  iw(0xE5801008,0xE2811005,0); iw(0xE2811005,0xE590100C,0); iw($NOP,0xE580100C,0);
  # Phase 2: D_IMEM 16 words (4 DW)
  iw(0xEE000A10,0xE3A00000,0); iw(0xE3A01010,0xEE010A10,0);
  iw(0xE3A02005,0xEE021A10,0); iw($NOP,0xEE032A10,0);
  # Phase 3: D_UNPACK (4 DW)
  iw(0xEE000A10,0xE3A00010,0); iw(0xEE011A10,0xE3A01000,0);
  iw(0xEE022A10,0xE3A02001,0); iw(0xEE033A10,0xE3A03041,0);
  # Phase 4: GPU K1 pc=0 (3+4=7 DW)
  iw(0xEE040A10,0xE3A00000,0); iw(0xEE071A10,0xE3A0100F,0);
  iw(0xEE052A10,0xE3A02001,0); for(1..4){np()}
  # Phase 5: GPU K2 pc=8 (3+4=7 DW)
  iw(0xEE040A10,0xE3A00008,0); iw(0xEE071A10,0xE3A0100F,0);
  iw(0xEE052A10,0xE3A02001,0); for(1..4){np()}
  # Phase 6: D_PACK (4 DW)
  iw(0xEE000A10,0xE3A00000,0); iw(0xEE011A10,0xE3A01018,0);
  iw(0xEE022A10,0xE3A02001,0); iw(0xEE033A10,0xE3A03043,0);
  # Phase 7: CPU +7 (8+1=9 DW incl NOP pair for D_PACK margin)
  np();
  iw(0xE3A02080,0xE3A00060,0); iw(0xE2811007,0xE5901000,0);
  iw(0xE5901004,0xE5821000,0); iw(0xE5821004,0xE2811007,0);
  iw(0xE2811007,0xE5901008,0); iw(0xE590100C,0xE5821008,0);
  iw(0xE582100C,0xE2811007,0); iw($NOP,$HALT,0);
  # K1 int x2: LD->ADD R,R->ST
  @c=cw(2,0,4,0); iw($c[0],$c[1],0);
  iw(0x10100000,0x20000000,0); iw(0x08200000,0x30211000,0);
  iw(0x08300001,0x20300000,0); iw(0xC8000000,0x00000000,0);
  # K2 int +10: LD->MOVI 10->ADD->ST
  @c=cw(2,8,4,0); iw($c[0],$c[1],0);
  iw(0x10100000,0x20000000,0); iw(0x30312000,0x2020000A,0);
  iw(0x20400000,0x08300000,0); iw(0xC8000000,0x08400001,0);
  # Input [10,20,30,40]
  @c=cw(2,0x010,2,0); iw($c[0],$c[1],0); iw(0x14,0x0A,0); iw(0x28,0x1E,0);
  # Zero readback
  @c=cw(2,0x020,2,0); iw($c[0],$c[1],0); iw(0,0,0); iw(0,0,0);
  @c=cw(3,0,0,0); iw($c[0],$c[1],0); @c=cw(4,0x020,2,0); iw($c[0],$c[1],0); @c=cw(5,0,0,0); iw($c[0],$c[1],0);
  id(); c4("T22",pt(400),cr(),0x43,0x2F,0x6B,0x57); }

