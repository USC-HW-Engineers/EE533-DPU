#!/usr/bin/perl -w
# socreg.pl v3.0 — NetFPGA SoC HW test suite (40 tests)
# Skips T2 (MUL) and T7 (MLA) — CPU mult removed.
# All encodings verified against soc_tb.v v6.0.
use strict;
use Time::HiRes qw(usleep gettimeofday tv_interval);

my $SW_DATA_HI  = 0x2000200; my $SW_DATA_LO  = 0x2000204;
my $SW_CTRL     = 0x2000208; my $SW_CMD       = 0x200020c;
my $HW_ST       = 0x2000210;
my $HW_W0H      = 0x2000214; my $HW_W0L      = 0x2000218;
my $HW_W1H      = 0x200021c; my $HW_W1L      = 0x2000220;
my $NOP = 0xE1A00000; my $HALT = 0xEAFFFFFE;
my ($pass,$fail,$txn,$err) = (0,0,0,0);
my ($ps,$wc,$V) = (0,0,1);

sub rw { my($a,$v)=@_; $v&=0xFFFFFFFF; $txn++; system(sprintf("regwrite 0x%08x 0x%08x >/dev/null 2>&1",$a,$v)); }
sub rr { my($a)=@_; $txn++; my @o=`regread 0x${\sprintf("%08x",$a)} 2>/dev/null`; for(@o){return hex($1) if/:\s+(0x[0-9a-f]+)/i} $err++; return 0; }
sub ds { my($s,$l)=@_; printf("    [%s] st=%08x rdy=%d buf=%d dr=%d drd=%d txa=%d txd=%d txw=%d pkt=%d\n",$l,$s,($s>>7)&1,($s>>8)&0x3F,($s>>4)&1,($s>>5)&1,($s>>3)&1,($s>>2)&1,($s>>16)&0x3F,$s&3) if $V; }
sub rs { my $s=rr($HW_ST); ds($s,$_[0]||"st"); $s }
sub ic { rw($SW_CMD,0x06); usleep(10000); rw($SW_CMD,0x02); usleep(1000); $ps=0; $wc=0; }
sub iw { my($h,$l,$c)=@_; rw($SW_DATA_HI,$h); rw($SW_DATA_LO,$l); rw($SW_CTRL,$c); $ps^=1; rw($SW_CMD,0x02|$ps); usleep(500); $wc++; }
sub id { printf("  [DRAIN] %d words\n",$wc); rw($SW_CMD,0x0A|$ps); usleep(1000); for(0..19){usleep(5000);my$s=rr($HW_ST);last if($s>>5)&1} }
sub np { iw($NOP,$NOP,0); }
sub cw { my($o,$a,$n,$p)=@_; ((($o&0xF)<<28)|(($a&0xFFF)<<16)|($n&0xFFFF), $p&0xFFFFFFFF) }
sub pt { my($n,$ms)=@_; $n||=200; $ms||=50; for(0..$n-1){usleep($ms*1000);my$s=rr($HW_ST);if(($s>>2)&1){printf("  [POLL] done @ %d\n",$_+1);return 1}} print "  [TIMEOUT]\n"; 0 }
sub cr { my@w; for my$r($HW_W0H,$HW_W0L,$HW_W1H,$HW_W1L){push@w,rr($r)} printf("  TX[0]=%08X_%08X TX[1]=%08X_%08X\n",@w); @w }
sub c4 { my($l,$d,$g0,$g1,$g2,$g3,$e0,$e1,$e2,$e3)=@_;
  if(!$d){print "  [FAIL] $l timeout\n";$fail++;return}
  for([0,$g0,$g1,$e0,$e1],[1,$g2,$g3,$e2,$e3]){my($i,$gh,$gl,$eh,$el)=@$_;
    if($gh==$eh&&$gl==$el){printf("  [PASS] $l TX[%d]={%X,%X}\n",$i,$gh,$gl);$pass++}
    else{printf("  [FAIL] $l TX[%d]={%X,%X} exp {%X,%X}\n",$i,$gh,$gl,$eh,$el);$fail++}}}
sub banner { print "\n" . "=" x 60 . "\n  $_[0]\n" . "=" x 60 . "\n\n" }

# ── Compact GPU ARM template ──────────────────────────────────
# Generates LOAD_IMEM + ARM program for: D_IMEM(16) → [D_UNPACK] → GPU → D_PACK
# D_IMEM always transfers 16 words (matching send_gpu_imem count=8 DWs)
sub gpu_arm {
  my($ctrl,$du,$dsrc,$dlen,$gnop)=@_;  # dunpack_len(0=skip), dpack_src, dpack_len, gpu_nop_pairs
  my $has_u = $du>0 ? 1 : 0;
  my $dws = 4 + $has_u*4 + 3+$gnop + 6;
  my @c=cw(1,0,$dws,0); iw($c[0],$c[1],$ctrl);
  # D_IMEM: CR0=0,CR1=0,CR2=16,CR3=5
  iw(0xEE000A10,0xE3A00000,0); iw(0xE3A01010,0xEE010A10,0);
  iw(0xE3A02005,0xEE021A10,0); iw($NOP,0xEE032A10,0);
  if($has_u){ # D_UNPACK: CR0=16,CR1=0,CR2=du,CR3=65
    iw(0xEE000A10,0xE3A00010,0); iw(0xEE011A10,0xE3A01000,0);
    iw(0xEE022A10,0xE3A02000|($du&0xFF),0); iw(0xEE033A10,0xE3A03041,0);
  }
  # GPU launch: CR4=0,CR7=15,CR5=1
  iw(0xEE040A10,0xE3A00000,0); iw(0xEE071A10,0xE3A0100F,0);
  iw(0xEE052A10,0xE3A02001,0);
  for(1..$gnop){np()}
  # D_PACK: CR0=src,CR1=32,CR2=dlen,CR3=67
  iw(0xEE000A10,0xE3A00000|($dsrc&0xFF),0); iw(0xEE011A10,0xE3A01020,0);
  iw(0xEE022A10,0xE3A02000|($dlen&0xFF),0); iw(0xEE033A10,0xE3A03043,0);
  np(); iw($NOP,$HALT,0);
}

# ── Tail: zero readback + 3 action commands ───────────────────
sub tail { my($ra,$rc)=@_;  # readback_addr, readback_dw_count
  my@c=cw(2,$ra,$rc,0); iw($c[0],$c[1],0);
  for(1..$rc){iw(0,0,0)}
  @c=cw(3,0,0,0);     iw($c[0],$c[1],0);
  @c=cw(4,$ra,$rc,0); iw($c[0],$c[1],0);
  @c=cw(5,0,0,0);     iw($c[0],$c[1],0);
}

